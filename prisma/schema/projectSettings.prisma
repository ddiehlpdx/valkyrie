enum TurnSystem {
  Initiative
  RoundRobin
  PhaseBased
}

enum StatGrowthModel {
  ClassBased
  Individual
  Hybrid
}

model ProjectSettings {
  id        String @id @default(uuid())
  projectId String @unique

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Grid defaults
  defaultGridSizeX Int @default(10)
  defaultGridSizeY Int @default(10)
  defaultTileSize  Int @default(32)

  // Battle config
  turnSystem        TurnSystem @default(Initiative)
  maxUnitsPerBattle Int        @default(8)

  // Progression
  maxLevel        Int             @default(99)
  statGrowthModel StatGrowthModel @default(ClassBased)

  // Base damage type colors
  physicalColor      String @default("#d4d4d4")
  magicalColor       String @default("#d4d4d4")
  chemicalColor      String @default("#d4d4d4")
  environmentalColor String @default("#d4d4d4")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
