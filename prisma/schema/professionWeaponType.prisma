model ProfessionWeaponType {
  id           String @id @default(uuid())
  professionId String
  weaponTypeId String
  projectId    String

  profession Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  weaponType WeaponType @relation(fields: [weaponTypeId], references: [id], onDelete: Cascade)
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([professionId, weaponTypeId])
}
