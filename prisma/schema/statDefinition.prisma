enum SystemStatKey {
  HP
  MP
  MOV
}

model StatDefinition {
  id           String         @id @default(uuid())
  name         String
  abbreviation String
  description  String?
  systemKey    SystemStatKey?
  group        String?
  minValue     Int
  maxValue     Int
  defaultValue Int
  isPercentage Boolean
  projectId    String

  project                  Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusEffectModifiers    StatusEffectStatModifier[]

  displayOrder Int      @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, abbreviation])
  @@unique([projectId, systemKey])
}
