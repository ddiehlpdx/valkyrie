enum CategoryType {
  Core
  Offensive
  Defensive
  Speed
  Luck
  Custom
}

model StatDefinition {
  id           String       @id @default(uuid())
  name         String
  abbreviation String
  description  String?
  category     CategoryType
  minValue     Int
  maxValue     Int
  defaultValue Int
  isPercentage Boolean
  projectId    String

  project                  Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusEffectModifiers    StatusEffectStatModifier[]

  displayOrder Int      @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, abbreviation])
}
