model ElementInteraction {
  id              String @id @default(uuid())
  sourceElementId String
  targetElementId String
  multiplier      Float  @default(1.0)
  projectId       String

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceElement Element @relation("SourceInteractions", fields: [sourceElementId], references: [id], onDelete: Cascade)
  targetElement Element @relation("TargetInteractions", fields: [targetElementId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, sourceElementId, targetElementId])
}