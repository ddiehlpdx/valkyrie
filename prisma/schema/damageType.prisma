model DamageType {
  id          String         @id @default(uuid())
  name        String
  description String?
  baseType    BaseDamageType
  color       String         @default("#808080")
  iconKey     String         @default("CircleDot")
  projectId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  weaponTypes        WeaponType[]
  sourceInteractions DamageTypeInteraction[] @relation("SourceDamageType")
  targetInteractions DamageTypeInteraction[] @relation("TargetDamageType")

  displayOrder Int      @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum BaseDamageType {
  Physical
  Magical
  Chemical
  Environmental
}
