model AbilityType {
  id        String @id @default(uuid())
  name      String
  projectId String

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  abilities Ability[]

  displayOrder Int      @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
