model StatusEffectStatModifier {
  id             String       @id @default(uuid())
  statusEffectId String
  statId         String
  modifierType   ModifierType @default(Flat)
  value          Float
  projectId      String

  statusEffect   StatusEffect   @relation(fields: [statusEffectId], references: [id], onDelete: Cascade)
  statDefinition StatDefinition @relation(fields: [statId], references: [id], onDelete: Cascade)
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([statusEffectId, statId])
  @@index([statId])
}

enum ModifierType {
  Flat
  Percentage
}
