model WeaponType {
  id           String  @id @default(uuid())
  name         String
  iconKey      String  @default("CircleDot")
  projectId    String
  damageTypeId String?
  twoHanded    Boolean @default(false)

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  damageType DamageType? @relation(fields: [damageTypeId], references: [id], onDelete: SetNull)

  professions ProfessionWeaponType[]

  displayOrder Int      @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
